import numpy as np

# Step 1 : Generate a Sample CT Image for demo

def create_sample_ct(size=256):
    
    image = np.random.normal(40, 15, (size, size))
    
    x, y = np.ogrid[:size, :size]
    
    center_x = size // 2
    center_y = size // 2
    
    pelvis = ((x - center_x) ** 2) / (70 ** 2) + \
             ((y - center_y) ** 2) / (90 ** 2)
             
    image[pelvis <= 1] += 160
    
    return image
